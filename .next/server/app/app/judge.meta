{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/judge/layout,_N_T_/app/judge/page,_N_T_/app/judge"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/judge/__PAGE__",
    "/app/judge",
    "/app",
    "/_index",
    "/_head"
  ]
}