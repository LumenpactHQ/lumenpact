{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/create/layout,_N_T_/app/create/page,_N_T_/app/create"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/create/__PAGE__",
    "/app/create",
    "/app",
    "/_index",
    "/_head"
  ]
}