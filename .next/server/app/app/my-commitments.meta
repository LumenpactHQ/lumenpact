{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/my-commitments/layout,_N_T_/app/my-commitments/page,_N_T_/app/my-commitments"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/my-commitments/__PAGE__",
    "/app/my-commitments",
    "/app",
    "/_index",
    "/_head"
  ]
}